PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# PostgreSQL Database Configuration
# You can use a unified DATABASE_URL or specify individual parameters below
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sunithaprasad_db
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=sunithaprasad_db

# Razorpay Integration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Quote if secret contains # (e.g. "#Sunithaprasad5000")
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
# Admin revenue analytics: gateway fee % and GST on fee (default 2% + 18%)
RAZORPAY_FEE_PERCENT=2
RAZORPAY_FEE_GST_PERCENT=18
# Checkout line item: payment gateway charges (default 2.4%)
PAYMENT_GATEWAY_CHARGE_PERCENT=2.4

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ImageKit Integration
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key

# Resend (order confirmation emails)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Sunitha Prasad Fashion World <orders@sunithaprasadfashionworld.in>
